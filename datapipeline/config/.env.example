# YouTube Data API v3 OAuth credentials, used to upload finished clips to
# YouTube Shorts. Create an OAuth 2.0 Client ID in Google Cloud Console
# (APIs & Services > Credentials) with the YouTube Data API v3 enabled, then
# run the OAuth consent flow once to obtain a long-lived refresh token.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# YouTube Data API v3 server key (not OAuth), used solely to fetch comment
# threads for the clip-detection social signal. Create a plain API key (not an
# OAuth client) in Google Cloud Console under the same project. This is
# intentionally separate from the OAuth posting creds above.
# Note: transcript fetching requires NO key but depends on the video having
# public captions enabled by the creator.
YOUTUBE_API_KEY=

# TikTok Content Posting API app credentials, used to upload clips directly
# to TikTok. Register an app at developers.tiktok.com, enable the Content
# Posting API product, and complete the OAuth flow to get an access token
# scoped to video.publish.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# Instagram Graph API credentials, used to publish clips as Reels. Generate
# a long-lived access token for a Facebook app connected to an Instagram
# Business/Creator account (developers.facebook.com), and set
# INSTAGRAM_ACCOUNT_ID to that account's numeric Instagram Business Account ID
# (the account Reels will be posted to).
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
